# mind-ar depends on `canvas`, a native Node addon used only by mind-ar's
# offline/Node-side tooling (e.g. its .mind target compiler) — never by the
# browser bundle (mindar-image-three.prod.js) this app actually loads at
# runtime via ImageTrackingViewer.tsx. Railway's build image lacks the
# pixman/cairo system libraries canvas needs to compile from source, and no
# prebuilt binary exists for the Node version Railway uses, so `npm install`
# fails there without this.
#
# Skipping install scripts avoids compiling canvas (and any other native
# addon) entirely, which is safe here since nothing at runtime touches it.
ignore-scripts=true
